# Copia este archivo a .env.local para probar en tu ordenador, o pega estas
# variables en Vercel → Settings → Environment Variables al desplegar.

# Tu clave de la API de Anthropic (https://console.anthropic.com/ → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# (Opcional) Modelo a usar. Por defecto claude-sonnet-4-6.
# Para gastar aún menos: claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
